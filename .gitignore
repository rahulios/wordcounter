# Build / dist / PyInstaller
build/
dist/
# Hand-edited .spec files ARE tracked; only ignore PyInstaller's auto-generated
# ones by matching the known generated names explicitly if/when they appear.

# Installers / binaries
*.exe
*.msi

# Runtime logs and caches
*.log
word_count.json

# Backups folder (local only)
backups/

# Per-user runtime state. The app reads/writes these from the platform
# app-data dir (~/Library/Application Support/WordCounterPro/ on macOS,
# %APPDATA%\WordCounterPro\ on Windows). Any copy at the repo root is
# local-only and must not be committed -- it would leak personal writing
# history and window/session state to anyone with repo access. Defaults
# for config.json live in Config.DEFAULT_CONFIG inside wordcounter.py.
WordCountData.xlsx
config.json

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
